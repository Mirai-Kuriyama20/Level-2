<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">
    <persistence-unit name="default" transaction-type="RESOURCE_LOCAL">
        <description>JpaForBeginners</description>
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        <class>com.example.level2.model.Author</class>
        <class>com.example.level2.model.Publisher</class>
        <class>com.example.level2.model.Book</class>
        <class>com.example.level2.model.User</class>
        <exclude-unlisted-classes>false</exclude-unlisted-classes>
        <properties>
            <!-- database connection -->
            <property name="jakarta.persistence.jdbc.driver" value="com.microsoft.sqlserver.jdbc.SQLServerDriver"/>
            <property name="jakarta.persistence.jdbc.url"
                      value="jdbc:sqlserver://localhost:1433;DatabaseName=BookDBI;encrypt=true;trustServerCertificate=true;loginTimeout=30;"/>
            <property name="jakarta.persistence.jdbc.user" value="minh"/>
            <property name="jakarta.persistence.jdbc.password" value="123456"/>

            <!-- Hibernate-specific property to disable autocommit (standard for JPA) -->
            <property name="hibernate.connection.autocommit" value="false"/>
            <!-- Remove JTA platform integration as it's not needed for simple Swing/Web apps -->
            <!-- <property name="hibernate.transaction.jta.platform" value="true"/> -->

            <!--            <property name="hibernate.dialect" value="org.hibernate.dialect.SQLServerDialect"/>-->
            <property name="hibernate.show_sql" value="true"/>

            <!--
                        https://thorben-janssen.com/generate-database-schema-jpa/
            -->
            <property name="jakarta.persistence.schema-generation.database.action" value="none"/>
            <property name="hibernate.hbm2ddl.auto" value="none"/>
            <!--            <property name="jakarta.persistence.schema-generation.scripts.action" value="drop-and-create"/>-->
            <!--            <property name="jakarta.persistence.schema-generation.scripts.create-target" value="META-INF/create.sql"/>-->

            <!-- <property name="jakarta.persistence.sql-load-script-source" value="create.sql"/> -->

        </properties>
    </persistence-unit>
</persistence>
